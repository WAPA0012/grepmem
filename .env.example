# Grepmem — example environment configuration
#
# Copy to `.env` and fill in. Most users only need MEMORY_PATH.
# Eval scripts need LLM_* for the agent-as-retriever benchmark.

# ─── Production (server.mjs / mcp-server.mjs) ──────────────────────────────

# Where to store memory.html. Default: ./namespaces/default
# Switch to isolate per-project / per-user / per-agent memory.
MEMORY_PATH=./namespaces/default

# HTTP server port (server.mjs only). Default: 18234
# MEMORY_PORT=18234


# ─── Eval scripts (eval/longmemeval-s-agent.mjs etc.) ──────────────────────

# LLM provider for the agent-as-retriever loop.
# StepFun Step Plan endpoint is recommended (5 concurrent requests on free tier,
# no RPM limit). Replace with your own key.
# LLM_KEY=your_stepfun_api_key
# LLM_BASE=https://api.stepfun.com/step_plan/v1
# LLM_MODEL=step-3.7-flash

# Alternative: any OpenAI-compatible endpoint (OpenAI, OpenRouter, Ollama, etc.)
# LLM_KEY=sk-...
# LLM_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Sampling budget
# MAX_TURNS=10            # Tool calls per question
# CONCURRENCY=4           # Parallel questions
# LIMIT=500               # Total questions to run
# RESUME=1                # 1 = resume from checkpoint, 0 = start fresh
